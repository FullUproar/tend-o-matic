{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --filter=@tend-o-matic/backoffice...",
  "buildCommand": "cd ../.. && pnpm --filter @tend-o-matic/backoffice build",
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "0 7 * * *"
    }
  ]
}
