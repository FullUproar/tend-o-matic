# Postgres connection URL used by Prisma migrate / generate.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://tend_o_matic:dev@localhost:5432/tend_o_matic_dev?schema=public"

# Optional: a separate role that has BYPASSRLS for super-admin /
# portal cross-tenant queries. Not used in this package directly;
# consumed by apps/portal.
DATABASE_URL_ADMIN="postgresql://tend_o_matic_admin:dev@localhost:5432/tend_o_matic_dev?schema=public"
